# LOCAL DEVELOPMENT ONLY — safe to commit (contains no real secrets).
# Loaded automatically when the backend runs with NODE_ENV=development (npm run dev / seed:dev).

# Local database (Docker container from docker-compose.dev.yml) — NOT production
MONGO_URI=mongodb://localhost:27017/delhiveryway_dev

# Auth (dummy values — fine for local only)
JWT_SECRET=dev-jwt-secret-not-for-production
JWT_EXPIRES_IN=7d
SESSION_SECRET=dev-session-secret-not-for-production

# Server
PORT=5000
NODE_ENV=development

# Local frontend origins (used for CORS)
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001
SHOPPER_FRONTEND_URL=http://localhost:3002
SHOPKEEPER_FRONTEND_URL=http://localhost:3003

# Email -> Mailhog. Every mail is caught locally at http://localhost:8025; nothing is sent out.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
MAIL_FROM=DelhiveryWay Dev <dev@delhiveryway.local>
GMAIL_USER=dev@delhiveryway.local

# File upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Stripe: placeholder so the SDK initializes at startup. It is NOT a real key,
# so payment calls will fail by design — replace with a real sk_test_... key only
# if you need to exercise payments locally. Google OAuth is intentionally omitted.
STRIPE_SECRET_KEY=sk_test_placeholder_local_dev_only
STRIPE_WEBHOOK_SECRET=whsec_placeholder_local_dev_only

# Built-in system admin (set real values in .env; never commit secrets)
ADMIN_EMAIL=admin@delhiveryway.com
ADMIN_PASSWORD=change-me-in-env
